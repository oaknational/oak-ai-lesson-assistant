+/**
+ * Tests for quiz pairing utility functions
+ */
+import {
+  type MatchMap,
+  type MatchPair,
+  type OrderMap,
+  createMatchPairings,
+  createOrderMapping,
+  findMatchingLeftLabel,
+  getItemPosition,
+} from "./pairing";
+
+describe("createMatchPairings", () => {
+  it("should create correct pairings for valid pairs", () => {
+    const pairs: MatchPair[] = [
+      { left: "Dog", right: "Bark" },
+      { left: "Cat", right: "Meow" },
+      { left: "Cow", right: "Moo" },
+    ];
+
+    const result = createMatchPairings(pairs);
+
+    expect(result.size).toBe(3);
+    expect(result.get("Dog")).toEqual({ rightText: "Bark", originalIndex: 0 });
+    expect(result.get("Cat")).toEqual({ rightText: "Meow", originalIndex: 1 });
+    expect(result.get("Cow")).toEqual({ rightText: "Moo", originalIndex: 2 });
+  });
+
+  it("should handle empty pairs array", () => {
+    const pairs: MatchPair[] = [];
+    const result = createMatchPairings(pairs);
+
+    expect(result.size).toBe(0);
+  });
+});
+
+describe("findMatchingLeftLabel", () => {
+  let correctMatches: MatchMap;
+  let leftItems: string[];
+
+  beforeEach(() => {
+    const pairs: MatchPair[] = [
+      { left: "Dog", right: "Bark" },
+      { left: "Cat", right: "Meow" },
+      { left: "Cow", right: "Moo" },
+    ];
+    correctMatches = createMatchPairings(pairs);
+    leftItems = ["Dog", "Cat", "Cow"];
+  });
+
+  it("should return correct left label for valid right item", () => {
+    expect(findMatchingLeftLabel("Bark", correctMatches, leftItems)).toBe("A");
+    expect(findMatchingLeftLabel("Meow", correctMatches, leftItems)).toBe("B");
+    expect(findMatchingLeftLabel("Moo", correctMatches, leftItems)).toBe("C");
+  });
+
+  it("should handle shuffled left items correctly", () => {
+    const shuffledLeftItems = ["Cat", "Cow", "Dog"]; // Different order
+
+    expect(
+      findMatchingLeftLabel("Bark", correctMatches, shuffledLeftItems),
+    ).toBe("C"); // Dog is now at index 2
+    expect(
+      findMatchingLeftLabel("Meow", correctMatches, shuffledLeftItems),
+    ).toBe("A"); // Cat is now at index 0
+    expect(
+      findMatchingLeftLabel("Moo", correctMatches, shuffledLeftItems),
+    ).toBe("B"); // Cow is now at index 1
+  });
+});
+
+describe("createOrderMapping", () => {
+  it("should create correct 1-indexed position mapping", () => {
+    const items = ["First", "Second", "Third", "Fourth"];
+    const result = createOrderMapping(items);
+
+    expect(result.size).toBe(4);
+    expect(result.get("First")).toBe(1);
+    expect(result.get("Second")).toBe(2);
+    expect(result.get("Third")).toBe(3);
+    expect(result.get("Fourth")).toBe(4);
+  });
+
+  it("should handle empty items array", () => {
+    const items: string[] = [];
+    const result = createOrderMapping(items);
+
+    expect(result.size).toBe(0);
+  });
+
+  it("should handle single item", () => {
+    const items = ["Only"];
+    const result = createOrderMapping(items);
+
+    expect(result.size).toBe(1);
+    expect(result.get("Only")).toBe(1);
+  });
+});
+
+describe("getItemPosition", () => {
+  let orderMap: OrderMap;
+
+  beforeEach(() => {
+    const items = ["First", "Second", "Third"];
+    orderMap = createOrderMapping(items);
+  });
+
+  it("should return correct position for valid items", () => {
+    expect(getItemPosition("First", orderMap)).toBe(1);
+    expect(getItemPosition("Second", orderMap)).toBe(2);
+    expect(getItemPosition("Third", orderMap)).toBe(3);
+  });
+});
+
+describe("Performance tests", () => {
+  it("should handle large datasets efficiently", () => {
+    // Create 1000 pairs
+    const largePairs: MatchPair[] = Array.from({ length: 1000 }, (_, i) => ({
+      left: `Left${i}`,
+      right: `Right${i}`,
+    }));
+
+    const start = performance.now();
+    const matches = createMatchPairings(largePairs);
+    const leftItems = largePairs.map((p) => p.left);
+
+    // Find a label in the middle
+    const label = findMatchingLeftLabel("Right500", matches, leftItems);
+    const end = performance.now();
+
+    expect(matches.size).toBe(1000);
+    expect(label).toBe("UG"); // String.fromCharCode(65 + 500) = "UG" (500 -> U=85, 500-26*19=6 -> G=71)
+    expect(end - start).toBeLessThan(100); // Should complete in under 100ms
+  });
+
+  it("should handle large order mapping efficiently", () => {
+    // Create 1000 items
+    const largeItems = Array.from({ length: 1000 }, (_, i) => `Item${i}`);
+
+    const start = performance.now();
+    const orderMap = createOrderMapping(largeItems);
+    const position = getItemPosition("Item500", orderMap);
+    const end = performance.now();
+
+    expect(orderMap.size).toBe(1000);
+    expect(position).toBe(501); // 0-indexed to 1-indexed
+    expect(end - start).toBeLessThan(50); // Should complete in under 50ms
+  });
+});
diff --git a/apps/nextjs/src/components/Quiz/utils/pairing.ts b/apps/nextjs/src/components/Quiz/utils/pairing.ts
new file mode 100644
index 00000000..fc96fabe
--- /dev/null
+++ b/apps/nextjs/src/components/Quiz/utils/pairing.ts
@@ -0,0 +1,72 @@
+/**
+ * Quiz Pairing Utilities
+ *
+ * Pure functions for handling quiz question pairing logic:
+ * - Match questions: pairing left and right items
+ * - Order questions: mapping items to their correct positions
+ */
+
+// Type definitions
+export type MatchPair = { left: string; right: string };
+export type MatchInfo = { rightText: string; originalIndex: number };
+export type MatchMap = Map<string, MatchInfo>;
+export type OrderMap = Map<string, number>;
+
+/**
+ * Creates a mapping from left items to their correct right matches
+ */
+export function createMatchPairings(pairs: MatchPair[]): MatchMap {
+  const correctMatches = new Map<string, MatchInfo>();
+
+  pairs.forEach((pair, originalIndex) => {
+    const leftText = pair.left;
+    const rightText = pair.right;
+    if (leftText && rightText) {
+      correctMatches.set(leftText, { rightText, originalIndex });
+    }
+  });
+
+  return correctMatches;
+}
+
+/**
+ * Finds the left label (A, B, C, etc.) that corresponds to a given right item
+ */
+export function findMatchingLeftLabel(
+  rightItem: string,
+  correctMatches: MatchMap,
+  leftItems: string[],
+): string {
+  for (const [leftText, matchInfo] of correctMatches.entries()) {
+    if (matchInfo.rightText === rightItem) {
+      const leftIndex = leftItems.findIndex((item) => item === leftText);
+      if (leftIndex !== -1) {
+        return String.fromCharCode(65 + leftIndex); // A, B, C, etc.
+      }
+    }
+  }
+  return "";
+}
+
+/**
+ * Creates a mapping from items to their correct positions (1-indexed)
+ */
+export function createOrderMapping(items: string[]): OrderMap {
+  const correctOrderMap = new Map<string, number>();
+
+  items.forEach((item, correctIndex) => {
+    correctOrderMap.set(item, correctIndex + 1);
+  });
+
+  return correctOrderMap;
+}
+
+/**
+ * Gets the correct position for an item from the order mapping
+ */
+export function getItemPosition(
+  item: string,
+  orderMap: OrderMap,
+): number | undefined {
+  return orderMap.get(item);
+}
