{
  "permissions": {
    "allow": [
      "Bash(scripts/check-prs.sh*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/agentic-scoring-reminder.sh"
          }
        ]
      }
    ]
  }
}
